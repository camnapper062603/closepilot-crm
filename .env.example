# Optional business lead enrichment providers for the standalone lead tooling.
APOLLO_API_KEY=
HUNTER_API_KEY=

# Optional bearer token/origin guard for the enrichment endpoint.
ENRICHMENT_CLIENT_TOKEN=
ENRICHMENT_ALLOWED_ORIGIN=https://camnapper062603.github.io

# Runtime mode. Use APP_MODE=beta and PUBLIC_DEMO_ENABLED=false for a company beta.
APP_MODE=development
PUBLIC_DEMO_ENABLED=true

# Supabase live database/auth configuration. The anon key may be Supabase's `sb_publishable_...` key.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe SaaS billing. Create recurring prices for each plan and add a webhook secret.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ADDON_RECRUIT=
STRIPE_PRICE_ADDON_LEADGEN=
STRIPE_PRICE_ADDON_BUNDLE=
STRIPE_PRODUCT_STARTER=
STRIPE_PRODUCT_GROWTH=
STRIPE_PRODUCT_SCALE=
STRIPE_METER_KEY=

# Public production app URL used for redirects, invite links, and API CORS.
APP_BASE_URL=http://localhost:4173
PRODUCT_URL=http://localhost:4173

# Resend email delivery for team invites and future email sends.
RESEND_API_KEY=
INVITE_FROM_EMAIL=invites@yourdomain.com
SUPPORT_EMAIL=support@kira.local

# Twilio SMS delivery. Leave blank to keep demo/log-only SMS mode.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Server-side AI. Leave blank to use deterministic fallback AI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Future Google Calendar/OAuth integration.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
